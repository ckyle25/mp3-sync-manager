<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mp3SyncManager.ViewModels"
             xmlns:models="using:Mp3SyncManager.Models"
             xmlns:conv="using:Avalonia.Data.Converters"
             x:Class="Mp3SyncManager.Views.LibraryView"
             x:DataType="vm:LibraryViewModel">

    <DockPanel>

        <!-- Pane header -->
        <Border DockPanel.Dock="Top"
                Background="#FAFAFA"
                BorderBrush="#E8E8E8"
                BorderThickness="0,0,1,1"
                Padding="16,0">
            <DockPanel Height="48">
                <TextBlock Text="Music Library"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left" />
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        Padding="12,4" />
            </DockPanel>
        </Border>

        <!-- Content area: all three state panels overlap in a Grid -->
        <Grid>

            <!-- Panel A: source folder missing -->
            <StackPanel IsVisible="{Binding SourceFolderMissing}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="280"
                        Spacing="8">
                <TextBlock Text="Folder Not Found"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="#C05000" />
                <TextBlock Text="The music folder is no longer available. Use the &quot;Choose New Folder&quot; button at the top of the window."
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="#777"
                           FontSize="13" />
            </StackPanel>

            <!-- Panel B: folder ok, no MP3 files -->
            <StackPanel IsVisible="{Binding ShowEmptyLibraryMessage}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="280"
                        Spacing="8">
                <TextBlock Text="No Music Files"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="#444" />
                <TextBlock Text="No music files were found in your folder. Add some songs and click Refresh."
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="#777"
                           FontSize="13" />
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0"
                        Padding="16,6" />
            </StackPanel>

            <!-- Panel C: three-column browser -->
            <DockPanel IsVisible="{Binding HasFiles}">

                <!-- Source path label: docked top -->
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding SourceFolderName, StringFormat='Source: {}{0}'}"
                           FontSize="12"
                           Foreground="#777"
                           Margin="12,8,12,4"
                           TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding SourceFolderPath}" />

                <!-- Action bar: docked bottom -->
                <Border DockPanel.Dock="Bottom"
                        Background="#F5F5F5"
                        BorderBrush="#E8E8E8"
                        BorderThickness="0,1,0,0"
                        Padding="12,10">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Add Album to Player"
                                    Command="{ReflectionBinding $parent[Window].DataContext.CopyAlbumToDeviceCommand}"
                                    Padding="14,6" />
                            <Button Content="Add Selected Songs"
                                    Command="{ReflectionBinding $parent[Window].DataContext.CopyToDeviceCommand}"
                                    Padding="14,6" />
                        </StackPanel>
                        <TextBlock Text="{ReflectionBinding $parent[Window].DataContext.CopyStatusMessage}"
                                   IsVisible="{ReflectionBinding $parent[Window].DataContext.CopyStatusMessage, Converter={x:Static conv:ObjectConverters.IsNotNull}}"
                                   FontSize="12"
                                   Foreground="#555"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Progress filename label: docked bottom, above action bar -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="{ReflectionBinding $parent[Window].DataContext.CopyProgressFileName}"
                           IsVisible="{ReflectionBinding $parent[Window].DataContext.IsCopying}"
                           FontSize="11"
                           Foreground="#777"
                           Margin="12,4,12,0"
                           TextTrimming="CharacterEllipsis" />

                <!-- Progress bar: docked bottom, above filename label -->
                <ProgressBar DockPanel.Dock="Bottom"
                             IsVisible="{ReflectionBinding $parent[Window].DataContext.IsCopying}"
                             Value="{ReflectionBinding $parent[Window].DataContext.CopyProgressPercent}"
                             Minimum="0"
                             Maximum="100"
                             Height="4"
                             Margin="0"
                             CornerRadius="0" />

                <!-- Three-column layout: Artists | Albums | Songs -->
                <Grid ColumnDefinitions="*,1,*,1,*">

                    <!-- Artists column -->
                    <DockPanel Grid.Column="0">
                        <!-- Column header -->
                        <Border DockPanel.Dock="Top"
                                BorderBrush="#E8E8E8"
                                BorderThickness="0,0,0,1"
                                Padding="10,6">
                            <TextBlock Text="ARTISTS"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#999"
                                       LetterSpacing="1" />
                        </Border>
                        <ListBox ItemsSource="{Binding Artists}"
                                 SelectedItem="{Binding SelectedArtist}"
                                 Margin="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:LibraryArtistViewModel">
                                    <TextBlock Text="{Binding Name}"
                                               Margin="6,2"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Divider: Artists / Albums -->
                    <Rectangle Grid.Column="1"
                               Fill="#E8E8E8"
                               Width="1"
                               HorizontalAlignment="Stretch" />

                    <!-- Albums column -->
                    <DockPanel Grid.Column="2">
                        <!-- Column header -->
                        <Border DockPanel.Dock="Top"
                                BorderBrush="#E8E8E8"
                                BorderThickness="0,0,0,1"
                                Padding="10,6">
                            <TextBlock Text="ALBUMS"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#999"
                                       LetterSpacing="1" />
                        </Border>

                        <!-- Albums: empty state when no artist is selected -->
                        <TextBlock DockPanel.Dock="Top"
                                   IsVisible="{Binding !HasArtistSelection}"
                                   Text="Pick an artist"
                                   FontSize="13"
                                   Foreground="#AAA"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,32,0,0" />

                        <!-- Albums list (only when an artist is selected) -->
                        <ListBox ItemsSource="{Binding CurrentAlbums}"
                                 SelectedItem="{Binding SelectedAlbum}"
                                 IsVisible="{Binding HasArtistSelection}"
                                 Margin="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:LibraryAlbumViewModel">
                                    <TextBlock Text="{Binding AlbumName}"
                                               Margin="6,2"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Divider: Albums / Songs -->
                    <Rectangle Grid.Column="3"
                               Fill="#E8E8E8"
                               Width="1"
                               HorizontalAlignment="Stretch" />

                    <!-- Songs column -->
                    <DockPanel Grid.Column="4">
                        <!-- Column header -->
                        <Border DockPanel.Dock="Top"
                                BorderBrush="#E8E8E8"
                                BorderThickness="0,0,0,1"
                                Padding="10,6">
                            <TextBlock Text="SONGS"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#999"
                                       LetterSpacing="1" />
                        </Border>

                        <!-- Songs: empty state when no album is selected -->
                        <TextBlock DockPanel.Dock="Top"
                                   IsVisible="{Binding !HasSelectedAlbum}"
                                   Text="Pick an album"
                                   FontSize="13"
                                   Foreground="#AAA"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,32,0,0" />

                        <!-- Songs list (only when an album with songs is selected) -->
                        <ListBox ItemsSource="{Binding CurrentSongs}"
                                 SelectionMode="Multiple"
                                 SelectedItems="{Binding SelectedFiles}"
                                 IsVisible="{Binding HasSelectedAlbum}"
                                 Margin="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:MusicFile">
                                    <DockPanel Margin="4,2">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding FileSizeFormatted}"
                                                   Foreground="#999"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                        <TextBlock Text="{Binding FileName}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   FontSize="13" />
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                </Grid>

            </DockPanel>

        </Grid>

    </DockPanel>

</UserControl>

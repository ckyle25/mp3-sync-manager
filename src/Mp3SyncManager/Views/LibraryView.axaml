<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Mp3SyncManager.ViewModels"
             xmlns:models="using:Mp3SyncManager.Models"
             xmlns:conv="using:Avalonia.Data.Converters"
             x:Class="Mp3SyncManager.Views.LibraryView"
             x:DataType="vm:LibraryViewModel">

    <DockPanel>

        <!-- Pane header -->
        <Border DockPanel.Dock="Top"
                Background="#FAFAFA"
                BorderBrush="#E8E8E8"
                BorderThickness="0,0,1,1"
                Padding="16,0">
            <DockPanel Height="48">
                <TextBlock Text="Music Library"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left" />
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        Padding="12,4" />
            </DockPanel>
        </Border>

        <!-- Content area -->
        <Grid>

            <!-- Panel A: source folder missing -->
            <StackPanel IsVisible="{Binding SourceFolderMissing}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="280"
                        Spacing="8">
                <TextBlock Text="Folder Not Found"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="#C05000" />
                <TextBlock Text="The music folder is no longer available. Use the &quot;Choose New Folder&quot; button at the top of the window."
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="#777"
                           FontSize="13" />
            </StackPanel>

            <!-- Panel B: folder ok, no MP3 files -->
            <StackPanel IsVisible="{Binding ShowEmptyLibraryMessage}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="280"
                        Spacing="8">
                <TextBlock Text="No Music Files"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="#444" />
                <TextBlock Text="No music files were found in your folder. Add some songs and click Refresh."
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="#777"
                           FontSize="13" />
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0"
                        Padding="16,6" />
            </StackPanel>

            <!-- Panel C: three-column browser -->
            <DockPanel IsVisible="{Binding HasFiles}">

                <!-- 1. Source path label: docked top -->
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding SourceFolderName, StringFormat='Source: {}{0}'}"
                           FontSize="12"
                           Foreground="#777"
                           Margin="16,8,16,4"
                           TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding SourceFolderPath}" />

                <!-- 2. Copy progress filename: docked bottom (above progress bar) -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="{ReflectionBinding $parent[Window].DataContext.CopyProgressFileName}"
                           IsVisible="{ReflectionBinding $parent[Window].DataContext.IsCopying}"
                           FontSize="11"
                           Foreground="#777"
                           Margin="12,4,12,0"
                           TextTrimming="CharacterEllipsis" />

                <!-- 3. Progress bar: docked bottom (above action bar) -->
                <ProgressBar DockPanel.Dock="Bottom"
                             IsVisible="{ReflectionBinding $parent[Window].DataContext.IsCopying}"
                             Value="{ReflectionBinding $parent[Window].DataContext.CopyProgressPercent}"
                             Minimum="0"
                             Maximum="100"
                             Height="4"
                             Margin="0"
                             CornerRadius="0" />

                <!-- 4. Action bar: docked bottom -->
                <Border DockPanel.Dock="Bottom"
                        Background="#F5F5F5"
                        BorderBrush="#E8E8E8"
                        BorderThickness="0,1,0,0"
                        Padding="12,10">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Add Album to Player"
                                    Command="{ReflectionBinding $parent[Window].DataContext.CopyAlbumToDeviceCommand}"
                                    IsEnabled="{Binding HasSelectedAlbum}"
                                    Padding="16,7"
                                    FontWeight="SemiBold" />
                            <Button Content="Add Selected Songs"
                                    Command="{ReflectionBinding $parent[Window].DataContext.CopyToDeviceCommand}"
                                    IsEnabled="{Binding HasSelectedFiles}"
                                    Padding="14,7" />
                        </StackPanel>
                        <TextBlock Text="{ReflectionBinding $parent[Window].DataContext.CopyStatusMessage}"
                                   IsVisible="{ReflectionBinding $parent[Window].DataContext.CopyStatusMessage, Converter={x:Static conv:ObjectConverters.IsNotNull}}"
                                   FontSize="12"
                                   Foreground="#555"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- 5. Three-column browser: fills remaining space -->
                <Grid ColumnDefinitions="*,Auto,*,Auto,*">

                    <!-- Column 0: Artists -->
                    <DockPanel Grid.Column="0">
                        <Border DockPanel.Dock="Top"
                                Background="#F5F5F5"
                                BorderBrush="#E8E8E8"
                                BorderThickness="0,0,0,1"
                                Padding="12,6">
                            <TextBlock Text="Artists"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#444" />
                        </Border>
                        <ListBox ItemsSource="{Binding Artists}"
                                 SelectedItem="{Binding SelectedArtist}"
                                 Margin="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:LibraryArtistViewModel">
                                    <TextBlock Text="{Binding Name}"
                                               Padding="4,3"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Divider between Artists and Albums -->
                    <Rectangle Grid.Column="1"
                               Width="1"
                               Fill="#E8E8E8"
                               HorizontalAlignment="Center" />

                    <!-- Column 1: Albums -->
                    <DockPanel Grid.Column="2">
                        <Border DockPanel.Dock="Top"
                                Background="#F5F5F5"
                                BorderBrush="#E8E8E8"
                                BorderThickness="0,0,0,1"
                                Padding="12,6">
                            <TextBlock Text="Albums"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#444" />
                        </Border>
                        <!-- Empty hint when no artist is selected -->
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Select an artist to see albums"
                                   IsVisible="{Binding !HasArtistSelection}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#999"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="16,24,16,0" />
                        <ListBox ItemsSource="{Binding CurrentAlbums}"
                                 SelectedItem="{Binding SelectedAlbum}"
                                 IsVisible="{Binding HasArtistSelection}"
                                 Margin="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:LibraryAlbumViewModel">
                                    <TextBlock Text="{Binding Name}"
                                               Padding="4,3"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- Divider between Albums and Songs -->
                    <Rectangle Grid.Column="3"
                               Width="1"
                               Fill="#E8E8E8"
                               HorizontalAlignment="Center" />

                    <!-- Column 2: Songs -->
                    <DockPanel Grid.Column="4">
                        <Border DockPanel.Dock="Top"
                                Background="#F5F5F5"
                                BorderBrush="#E8E8E8"
                                BorderThickness="0,0,0,1"
                                Padding="12,6">
                            <TextBlock Text="Songs"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#444" />
                        </Border>
                        <!-- Empty hint when no album is selected -->
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Select an album to see songs"
                                   IsVisible="{Binding !HasSelectedAlbum}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#999"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="16,24,16,0" />
                        <ListBox ItemsSource="{Binding CurrentSongs}"
                                 SelectionMode="Multiple"
                                 SelectedItems="{Binding SelectedFiles}"
                                 IsVisible="{Binding HasSelectedAlbum}"
                                 Margin="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:MusicFile">
                                    <DockPanel Margin="4,3">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding FileSizeFormatted}"
                                                   Foreground="#999"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0" />
                                        <TextBlock Text="{Binding FileName}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                </Grid>

            </DockPanel>

        </Grid>

    </DockPanel>

</UserControl>
